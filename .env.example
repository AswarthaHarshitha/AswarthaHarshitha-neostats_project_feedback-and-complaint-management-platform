# Example environment variables for local/dev and to know what to set in hosting
# Rename to .env locally for development. Do NOT commit secrets to the repo.

# Backend
MONGO_URI=mongodb://username:password@host:port/dbname
JWT_SECRET=replace-me
PORT=3000
NODE_ENV=production

# Frontend (if any public keys)
# NEXT_PUBLIC_API_BASE_URL=https://api.example.com
# Backend
MONGODB_URI=mongodb://127.0.0.1:27017/neoconnect
JWT_SECRET=super-secret-key
PORT=5000
CLIENT_URL=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:5000
